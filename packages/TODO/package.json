{
  "name": "TODO",
  "version": "0.0.0",
  "description": "TODO",
  "keywords": [
    "nextjs",
    "react",
    "ssr",
    "vite"
  ],
  "license": "MIT",
  "repository": "github:cyco130/TODO",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "rm -rf dist && pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json --noEmit",
    "test:lint": "eslint . --max-warnings 0 --ignore-pattern dist",
    "test:package": "publint"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^8.0.0",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.1",
    "publint": "^0.3.18",
    "tsdown": "0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "20 || 22 || 24 || 25"
  }
}
